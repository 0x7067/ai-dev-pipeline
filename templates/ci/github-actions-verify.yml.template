# Sample CI gate — copy to .github/workflows/verify.yml in consuming repo.
# Authoritative gate per .claude/rules/release-and-verification.md (Gate Authority).
name: verify

on:
  pull_request:
    branches: [main]

jobs:
  verify:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Detect Node.js (optional)
        if: hashFiles('package.json') != ''
        uses: actions/setup-node@v4
        with:
          node-version: lts/*

      - name: Detect Python (optional)
        if: hashFiles('pyproject.toml') != '' || hashFiles('setup.py') != ''
        uses: actions/setup-python@v5
        with:
          python-version: '3.x'

      - name: Detect Go (optional)
        if: hashFiles('go.mod') != ''
        uses: actions/setup-go@v5
        with:
          go-version: stable

      - name: Detect Rust (optional)
        if: hashFiles('Cargo.toml') != ''
        uses: dtolnay/rust-toolchain@stable

      - name: Run verification gates
        env:
          MAX_VERIFY_RETRIES: '0'
        run: bash scripts/run-verification-gates.sh

      - name: Upload verify report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: verify-report
          path: |
            docs/verify-report.md
            docs/.verify-retry.json
          if-no-files-found: ignore
